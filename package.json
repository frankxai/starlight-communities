{
  "name": "@starlight/communities",
  "version": "0.1.0",
  "description": "Agentic creation-cell operating system for production-grade communities.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/frankxai/starlight-communities.git"
  },
  "homepage": "https://github.com/frankxai/starlight-communities#readme",
  "bugs": {
    "url": "https://github.com/frankxai/starlight-communities/issues"
  },
  "engines": {
    "node": ">=20.11"
  },
  "bin": {
    "starlight-communities": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "hermes",
    "modules",
    "openclaw",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "validate": "pnpm typecheck && pnpm test && node scripts/validate-manifest.mjs",
    "start": "tsx src/cli.ts"
  },
  "dependencies": {
    "yaml": "^2.8.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
